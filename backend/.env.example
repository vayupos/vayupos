# Backend Environment Variables Example
# Copy this file to .env and fill in the values appropriately.

# Database Configuration
DATABASE_URL="postgresql+psycopg2://user:password@localhost:5432/vayu_pos"
# For Neon DB, you might use:
# DATABASE_URL="postgresql+psycopg2://<neon_user>:<neon_password>@<neon_endpoint>.neon.tech/neondb?sslmode=require"

# Security and Authentication
SECRET_KEY="your-super-secret-jwt-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Optional / Debug Settings
DEBUG=False
