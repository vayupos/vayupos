# Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL — get connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-strong-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ── App ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins — add every domain that hits the API
# The first non-localhost entry is also used as the base URL for password-reset emails
ALLOWED_ORIGINS=https://app.vayupos.com,https://admin.vayupos.com,https://vayupos.com,https://www.vayupos.com,https://vyoma-vayupos.pages.dev,http://localhost:8080,http://127.0.0.1:8080

# ── Admin ────────────────────────────────────────────────────────────────────
# Used to create superadmin and register new restaurants — keep this secret
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=your-strong-admin-key-here

# ── Cloudflare R2 (file storage) ─────────────────────────────────────────────
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=vayupos-uploads
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── SMTP (email) — optional, leave blank to use console fallback ─────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
EMAILS_FROM_EMAIL=noreply@vayupos.com
EMAILS_FROM_NAME=VayuPos Support
