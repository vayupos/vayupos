# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV: Copy this file to .env and fill in values below.
#            .env is never committed to git.
#
# PRODUCTION: Do NOT use .env for production.
#             Set these variables in the Cloudflare Pages dashboard:
#             Pages project → Settings → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Full API URL including the /api/v1 prefix.
# Used for all backend API calls (axios base URL).
# Local:      http://localhost:8000/api/v1
# Production: https://api.vayupos.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# API host without path — used to convert relative image URLs to absolute.
# Must match the origin of VITE_API_URL (no trailing slash, no /api/v1).
# Local:      http://localhost:8000
# Production: https://api.vayupos.com
VITE_API_HOST=http://localhost:8000
